#!/usr/bin/env python3
import argparse
import os
import sys

DEFAULT_POWER_STATE_PATH = '/sys/bus/pci/devices/0000:01:00.0/power_state'
VERSION = "1.0"

# ANSI Colors
GREEN = "\033[32m"
RESET = "\033[0m" # Reset default to color

# Returns a PCI address such as '0000:01:00.0' or 'None' if not found
def find_nvidia_pci_address():
    pci_dir = "/sys/bus/pci/devices"
    NVIDIA_VENDOR_ID = "0x10de"
    
    if not os.path.exists(pci_dir):
        return None
        
    for pci_address in os.listdir(pci_dir):
        vendor_file_path = os.path.join(pci_dir, pci_address, "vendor")
        try:
            with open(vendor_file_path, "r") as f:
                # The file contains the ID in hex format, e.g., '0x10de\n'
                if f.read().strip() == NVIDIA_VENDOR_ID:
                    return pci_address
        except (FileNotFoundError, PermissionError):
            # Skip directories we can't access or files that vanish mid-scan
            continue
            
    return None

def get_gpu_power_state():
    power_state_path = DEFAULT_POWER_STATE_PATH
    # Fallback to sysfs tree search if nv card does not have common path
    if not os.path.exists(power_state_path) and find_nvidia_pci_address() is not None:
        power_state_path = f"/sys/bus/pci/devices/{find_nvidia_pci_address()}/power_state"

    try:
        with open(power_state_path, 'r') as f:
            return f.read().strip()
    except FileNotFoundError:
        return "Unknown (Device file not found)"
    except Exception as e:
        return f"Unknown (Error: {e})"

def print_gpu_power_state():
    gpu_power_state = get_gpu_power_state().lower()
    hint = ""

    if gpu_power_state == "d0":
        hint = "Full Power"
    elif gpu_power_state == "d3cold":
        hint = "Sleep"
    elif gpu_power_state == "d3hot":
        hint = "Standby"

    print(f"State: {GREEN}{gpu_power_state}{RESET} ({hint})")

def print_env_vars():
    vulkan = os.environ.get('VK_LOADER_DRIVERS_DISABLE')
    opengl = os.environ.get('__EGL_VENDOR_LIBRARY_FILENAMES')

    if opengl is None:
        print("OpenGL (__EGL_VENDOR_LIBRARY_FILENAMES): null")
    else:
        print(f"OpenGL (__EGL_VENDOR_LIBRARY_FILENAMES): {opengl}")

    if vulkan is None:
        print("Vulkan (VK_LOADER_DRIVERS_DISABLE): null")
    else:
        print(f"Vulkan (VK_LOADER_DRIVERS_DISABLE): {vulkan}")

def main():
    parser = argparse.ArgumentParser(
        description="NVIDIA Prime Offload Launcher & Power Status Utility. Without arguments, nvrun will display this help menu. Provide an executable command to run it using the discrete NVIDIA GPU."
    )
    
    parser.add_argument("-s", "--status", action="store_true", help="Print the current hardware power state of the NVIDIA GPU (e.g., D3cold, D0).")
    parser.add_argument("-v", "--version", action="store_true", help="Print version info and exit.")
    parser.add_argument("-e", "--env", action="store_true", help="Print environment variables.")
    
    # parse_known_args returns a tuple: (parsed_namespace, list_of_remaining_unparsed_args)
    args, command_args = parser.parse_known_args()
    
    # Interpret options matching your structural flow
    if args.status and len(sys.argv) == 2:
        print_gpu_power_state()
        
    elif args.version and len(sys.argv) == 2:
        print(f"nvrun version {VERSION}")

    elif args.env and len(sys.argv) == 2:
        print_env_vars()
        
    elif command_args:
        # Lift the system-wide environment blindfold for this process tree
        os.environ.pop('VK_LOADER_DRIVERS_DISABLE', None)
        os.environ.pop('__EGL_VENDOR_LIBRARY_FILENAMES', None)

        # Inject standard NVIDIA Prime offload variables
        os.environ['__NV_PRIME_RENDER_OFFLOAD'] = '1'
        os.environ['__VK_LAYER_NV_optimus'] = 'NVIDIA_only'
        os.environ['__GLX_VENDOR_LIBRARY_NAME'] = 'nvidia'

        # Execute the application
        try:
            os.execvp(command_args[0], command_args)
        except FileNotFoundError:
            print(f"Error: Command '{command_args[0]}' not found in PATH.")
            sys.exit(127)
            
    else:
        parser.print_help()
        sys.exit(1)

if __name__ == '__main__':
    main()
